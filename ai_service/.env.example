# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: "openai" | "claude" | "google" | "minimax" | "kimi" | "zhipu" | "ollama"
LLM_PROVIDER=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6-20251106

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ── Minimax ───────────────────────────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat

# ── Kimi (Moonshot AI) ───────────────────────────────────────────────────────
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

# ── Zhipu AI (智谱AI) ─────────────────────────────────────────────────────────
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

# ── Ollama (local, free) ─────────────────────────────────────────────────────
# Install: https://ollama.com  →  then run: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Price settings ────────────────────────────────────────────────────────────
PRICE_CACHE_TTL=5
SYMBOL_CACHE_TTL=1800
CONFIDENCE_THRESHOLD=0.80
